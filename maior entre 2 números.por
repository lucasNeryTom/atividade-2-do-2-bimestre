programa
{
    funcao inicio()
    {
        real n1, n2

        escreva("Digite o primeiro numero: ")
        leia(n1)

        escreva("Digite o segundo numero: ")
        leia(n2)

        se (n1 >= n2)
        {
            escreva("Maior numero: ", n1)
        }
        senao
        {
            escreva("Maior numero: ", n2)
        }
    }
}
